{
    "openapi": "3.0.0",
    "info": {
        "title": "API de Gerenciamento de Usuários",
        "description": "API para cadastro, autenticação e gerenciamento de usuários.",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:8080",
            "description": "Servidor Local"
        }
    ],
    "paths": {
        "/auth/login": {
            "post": {
                "tags": [
                    "Autenticação"
                ],
                "summary": "Autenticação de Usuário",
                "operationId": "da7754cf89be7443bb1ad605740472e1",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "admin@nextsi.com.br"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "password"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login bem-sucedido, retorna o JWT",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "token": {
                                            "type": "string",
                                            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Payload inválido ou não formatado como JSON"
                    },
                    "401": {
                        "description": "Credenciais inválidas"
                    },
                    "422": {
                        "description": "E-mail ou senha ausentes ou com formato inválido"
                    },
                    "500": {
                        "description": "Erro interno do servidor"
                    }
                }
            }
        },
        "/users": {
            "get": {
                "tags": [
                    "Usuários"
                ],
                "summary": "Lista todos os usuários (Paginado)",
                "operationId": "3a7d6b9068feed30aa0f349ee7ab5edd",
                "parameters": [
                    {
                        "name": "limit",
                        "in": "query",
                        "description": "Limite de resultados",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 50
                        }
                    },
                    {
                        "name": "offset",
                        "in": "query",
                        "description": "Pular X resultados",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 0
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Lista de usuários retornada com sucesso"
                    },
                    "401": {
                        "description": "Não autorizado (Token ausente ou inválido)"
                    },
                    "422": {
                        "description": "Parâmetros de paginação inválidos"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Usuários"
                ],
                "summary": "Cria um novo usuário (Apenas Admin)",
                "operationId": "cb408da206e4313a2e37becbec2ec819",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "email",
                                    "password",
                                    "document"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Maria Teste"
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "maria@teste.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "senha_forte"
                                    },
                                    "document": {
                                        "type": "string",
                                        "example": "01001205553"
                                    },
                                    "phone": {
                                        "type": "string",
                                        "example": "14999999999"
                                    },
                                    "profile": {
                                        "type": "string",
                                        "example": "user",
                                        "enum": [
                                            "admin",
                                            "user"
                                        ]
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Usuário criado com sucesso"
                    },
                    "400": {
                        "description": "Payload inválido ou não formatado como JSON"
                    },
                    "401": {
                        "description": "Não autorizado"
                    },
                    "403": {
                        "description": "Acesso negado (Não é admin)"
                    },
                    "409": {
                        "description": "E-mail ou Documento já existem"
                    },
                    "422": {
                        "description": "Erro de validação (campos obrigatórios, CPF/CNPJ inválido)"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/users/{id}": {
            "get": {
                "tags": [
                    "Usuários"
                ],
                "summary": "Busca um usuário específico pelo ID",
                "operationId": "61a4430fceeef9d90aa3df42255c2b34",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID do usuário",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Dados do usuário"
                    },
                    "401": {
                        "description": "Não autorizado"
                    },
                    "404": {
                        "description": "Usuário não encontrado"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "put": {
                "tags": [
                    "Usuários"
                ],
                "summary": "Atualiza um usuário existente (Apenas Admin)",
                "operationId": "de688cd89a9bbcf57592f6fe4d37346e",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Maria Editada"
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "maria.nova@teste.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "nova_senha_forte"
                                    },
                                    "phone": {
                                        "type": "string",
                                        "example": null,
                                        "nullable": true
                                    },
                                    "profile": {
                                        "type": "string",
                                        "example": "admin",
                                        "enum": [
                                            "admin",
                                            "user"
                                        ]
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Usuário atualizado com sucesso"
                    },
                    "400": {
                        "description": "Payload inválido ou não formatado como JSON"
                    },
                    "401": {
                        "description": "Não autorizado"
                    },
                    "403": {
                        "description": "Acesso negado (Não é admin)"
                    },
                    "404": {
                        "description": "Usuário não encontrado"
                    },
                    "409": {
                        "description": "E-mail já está em uso por outra conta"
                    },
                    "422": {
                        "description": "Erro de validação nos campos enviados"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "delete": {
                "tags": [
                    "Usuários"
                ],
                "summary": "Deleta um usuário (Apenas Admin)",
                "operationId": "2c9d8e282cb12ada865a59b222952a17",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Usuário deletado com sucesso"
                    },
                    "401": {
                        "description": "Não autorizado"
                    },
                    "403": {
                        "description": "Acesso negado (Não é admin)"
                    },
                    "404": {
                        "description": "Usuário não encontrado"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        }
    },
    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "bearerFormat": "JWT",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Autenticação",
            "description": "Autenticação"
        },
        {
            "name": "Usuários",
            "description": "Usuários"
        }
    ]
}